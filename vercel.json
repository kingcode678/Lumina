{
  "rewrites": [
    {
      "source": "/api/prerender",
      "destination": "/api/prerender.js"
    },
    {
      "source": "/((?!api).*)",
      "destination": "/api/prerender?url=/$1"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Prerender-Token",
          "value": "IY4MbEsySXbfTCJ6sOkv"
        }
      ]
    }
  ]
}